# Agent Sandbox Configuration
# Copy this file to .sandbox.env and fill in your values

# Base directory where your projects live (default: parent of agent-sandbox)
# SANDBOX_BASE_DIR=/c/Dev

# Directory for git worktrees (default: $SANDBOX_BASE_DIR/.worktrees)
# SANDBOX_WORKTREE_DIR=/c/Dev/.worktrees

# Default provider (default: claude-code)
# SANDBOX_PROVIDER=claude-code

# Resource limits
# SANDBOX_CPU_LIMIT=8
# SANDBOX_MEMORY_LIMIT=16g
# SANDBOX_PID_LIMIT=2048

# Provider-specific env vars (see providers/<name>/README.md)
# For Claude Code: ANTHROPIC_API_KEY=sk-ant-...
# For Codex: OPENAI_API_KEY=sk-...
